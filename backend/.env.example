# Copy to .env and fill in to use the real Qwen (通义千问) agent loop.
# Leave unset to run the deterministic stub (no API calls, works offline).
# Get a key from https://dashscope.console.aliyun.com/ (DashScope / 阿里云百炼).
DASHSCOPE_API_KEY=

# Optional: override the model (default qwen-plus) or the base URL
# (default Beijing; use dashscope-intl.aliyuncs.com for the international region).
QWEN_MODEL=
DASHSCOPE_BASE_URL=

# Optional: comma-separated allowed CORS origins (default "*" for local dev).
# e.g. CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=
